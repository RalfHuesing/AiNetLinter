{
  "Global": {
    "EnforceSealedClasses": true,
    "AllowUnsealedPartialClasses": true,
    "AllowDynamic": false,
    "AllowOutParameters": false,
    "EnforceValueObjectContracts": true,
    "EnableTestSentinel": true,
    "EnforcePascalCase": true,
    "EnforceXmlDocumentation": false,
    "EnforceSemanticNaming": true,
    "EnforceNullableEnable": true,
    "EnforceNoSilentCatch": true,
    "AllowTryPatternOutParameters": true,
    "AllowCancellationShutdownCatch": true,
    "AllowOutParametersInPrivateMethods": true,
    "SemanticNamingExemptMethodNames": [
      "Equals",
      "CompareTo",
      "GetHashCode"
    ],
    "SemanticNamingAllowSubstringOfMethodName": true,
    "AllowedSilentCatchExceptionTypes": [
      "JSDisconnectedException",
      "JSException",
      "ObjectDisposedException"
    ],
    "EnforceMinimalApiAsParameters": true,
    "EnforceResultPatternOverExceptions": false,
    "ResultPatternAllowThrowInNamespaceSuffixes": [
      "Infrastructure",
      "Handlers",
      "Api",
      "Auth",
      "Middleware",
      "Program"
    ],
    "ResultPatternAllowCatchRethrow": true,
    "EnforceExplicitStateImmutability": false,
    "AllowedExceptions": [
      "ArgumentException",
      "ArgumentNullException",
      "ArgumentOutOfRangeException",
      "InvalidOperationException",
      "NotSupportedException",
      "KeyNotFoundException",
      "IndexOutOfRangeException",
      "TimeoutException",
      "ObjectDisposedException",
      "NotImplementedException"
    ],
    "PreventContextDependentOverloads": false,
    "EnforceNamespaceDirectoryMapping": false,
    "NamespaceDirectoryMappingMode": "suffix-match",
    "NamespaceDirectoryMappingIgnorePathSegments": [
      "Components",
      "Domains",
      "Handlers",
      "Pages",
      "Source",
      "src"
    ],
    "NamespaceDirectoryMappingRequiredTrailingSegments": 2,
    "DetectAndBanPhantomDependencies": true,
    "BanPublicNestedTypes": true,
    "BanPublicNestedTypesAllowPrivate": true,
    "ImmutabilityExemptSuffixes": [
      "Dto",
      "Entity",
      "Model",
      "Request",
      "Response",
      "Command",
      "Record",
      "Result",
      "Violation"
    ],
    "ImmutabilityExemptPatterns": [
      "*Options",
      "*Json",
      "*State",
      "*Payload",
      "*Input",
      "*Settings",
      "*Row",
      "*Entry",
      "*Notice",
      "*Patch",
      "*Config",
      "*Parameters",
      "*Cache",
      "*Context",
      "*Hub",
      "*Gate",
      "*Binder",
      "*Tracker",
      "*Store",
      "*Mapper",
      "*Converter",
      "*Resolver",
      "*Builder",
      "*Formatter",
      "*Catalog",
      "*Coordinator",
      "*Collector",
      "*Sandbox",
      "*Probe",
      "*Hasher",
      "*Material",
      "*Complete",
      "*Snapshot",
      "*Archive",
      "*Session",
      "*Turn",
      "*Message",
      "*Interop",
      "*Stack",
      "*Layout",
      "*Pane",
      "*Tree",
      "*Chrome",
      "*Preferences"
    ],
    "AllowedEmptyReads": false,
    "SealedClassExemptSuffixes": [
      "Base",
      "Foundation",
      "Host"
    ],
    "ImmutabilityExemptBaseTypes": [
      "ComponentBase",
      "LayoutComponentBase",
      "AuthenticationStateProvider",
      "BackgroundService"
    ],
    "ImmutabilityAllowPrivateBackingFields": false,
    "EnablePerformanceProfiling": true,
    "BanAsyncVoid": true,
    "AsyncVoidAllowEventHandlers": true,
    "BanBlockingTaskAccess": true,
    "BanBlockingTaskAccessAllowInMain": true,
    "BanBlockingTaskAccessAllowInTests": false
  },
  "Metrics": {
    "MaxLineCount": 600,
    "MaxMethodParameterCount": 6,
    "MaxMethodParameterCountInTestFiles": 0,
    "MethodParameterCountIgnoreTypeNames": [
      "CancellationToken"
    ],
    "MethodParameterCountIgnoreTypePrefixes": [
      "ILogger",
      "IOptions",
      "IOptionsSnapshot",
      "IOptionsMonitor",
      "IHostEnvironment",
      "IWebHostEnvironment",
      "IConfiguration",
      "IServiceProvider",
      "IHttpContextAccessor",
      "HttpContext",
      "TimeProvider",
      "LinkGenerator",
      "ProblemDetailsService"
    ],
    "MaxMethodParameterCountAllowPrivate": false,
    "MaxMethodParameterCountForNonPublic": 6,
    "MaxMethodLineCount": 60,
    "MaxCyclomaticComplexity": 12,
    "MaxCognitiveComplexity": 15,
    "MaxInheritanceDepth": 2,
    "MinCognitiveComplexityForTest": 3,
    "AggregatePartialClassLineCount": false,
    "MaxMethodOverloads": 3,
    "MaxConstructorDependencies": 5,
    "MaxDirectoryDepth": 7,
    "InheritanceDepthFrameworkPrefixes": [
      "Microsoft.AspNetCore.",
      "Microsoft.AspNetCore.Components.",
      "Microsoft.Extensions.",
      "MudBlazor.",
      "System."
    ],
    "ConstructorDependencyIgnoreTypePrefixes": [
      "ILogger",
      "IOptions",
      "IOptionsSnapshot",
      "IOptionsMonitor",
      "IHostEnvironment",
      "IWebHostEnvironment",
      "IConfiguration",
      "IServiceProvider",
      "IHttpContextAccessor"
    ],
    "ConstructorDependencyExemptClassSuffixes": [
      "Exception"
    ],
    "MaxAIContextFootprint": 5000,
    "FootprintIgnoreNamespacePrefixes": [],
    "FootprintIgnoreTypeNames": [
      "SqlExecutor",
      "DataTableDragDropSettings"
    ],
    "ComplexityNearMissTolerance": 1,
    "ExcludeSwitchDispatcherCases": true,
    "SwitchDispatcherMaxCaseBodyLines": 3,
    "ExcludeNullCoalescingInitializerComplexity": true,
    "NullCoalescingInitializerMaxNonCoalescingRatio": 0,
    "MaxSwitchArms": 10,
    "MaxSwitchArmsExcludeDispatcher": true,
    "MaxSwitchArmsExemptTypes": [],
    "MaxBoolParameterCount": 1,
    "MaxBoolParameterCountAllowPrivate": true,
    "MaxBoolParameterCountExemptMethodPrefixes": [
      "Try"
    ],
    "MaxDirectoryChildren": 0,
    "MaxDirectoryChildrenExemptNames": [
      "Migrations",
      "Generated",
      "wwwroot",
      "obj",
      "bin",
      ".git"
    ],
    "MaxPartialClassFiles": 2,
    "MaxPartialClassFilesExemptTypes": [],
    "MaxPublicMembersPerType": 15,
    "MaxPublicMembersPerTypeExemptSuffixes": [
      "Extensions",
      "Mapper",
      "Constants",
      "Config",
      "ConfigOverride",
      "Args"
    ],
    "MaxLinqChainLength": 0,
    "LinqMethodNames": [
      "Where",
      "Select",
      "SelectMany",
      "GroupBy",
      "GroupJoin",
      "Join",
      "OrderBy",
      "OrderByDescending",
      "ThenBy",
      "ThenByDescending",
      "Take",
      "TakeWhile",
      "Skip",
      "SkipWhile",
      "First",
      "FirstOrDefault",
      "Last",
      "LastOrDefault",
      "Single",
      "SingleOrDefault",
      "Count",
      "LongCount",
      "Any",
      "All",
      "Distinct",
      "DistinctBy",
      "Union",
      "UnionBy",
      "Intersect",
      "IntersectBy",
      "Except",
      "ExceptBy",
      "Aggregate",
      "Sum",
      "Min",
      "Max",
      "Average",
      "MinBy",
      "MaxBy",
      "ToList",
      "ToArray",
      "ToDictionary",
      "ToHashSet",
      "ToLookup",
      "Cast",
      "OfType",
      "Append",
      "Prepend",
      "Reverse",
      "Zip",
      "Chunk",
      "Flatten"
    ],
    "CompoundSuppressions": [
      {
        "TargetRule": "MaxMethodLineCount",
        "WhenAllOf": [
          {
            "Metric": "CyclomaticComplexity",
            "AtMost": 3
          },
          {
            "Metric": "CognitiveComplexity",
            "AtMost": 5
          }
        ],
        "RelaxedLimit": 150,
        "SeverityOverride": "warning",
        "Reason": "Initialisierungs- und Builder-Methoden sind semantisch flach. LOC bei CC\u22643 ist nicht mit Fehleranf\u00E4lligkeit korreliert (Palomba et al., 2018). \u00DCber 150 Zeilen: sichtbar als warning, kein Build-Fehler."
      }
    ]
  },
  "TestSentinel": {
    "ClassNamePatterns": [
      "{Name}Tests",
      "{Name}Test",
      "{Name}IntegrationTests",
      "{Name}*Tests"
    ],
    "RecognizeTypeofReference": true,
    "RecognizeCoversComment": true,
    "ExemptClassNameSuffixes": [
      "Extensions",
      "Constants",
      "Converter",
      "Profile",
      "Seed",
      "Migration",
      "Startup",
      "Module",
      "Coordinator"
    ],
    "ExemptWhenInheritsFrom": [
      "ComponentBase",
      "LayoutComponentBase",
      "IValueConverter",
      "Profile"
    ],
    "ExemptStaticClasses": true,
    "TestProjectNameSuffixes": [
      "Tests",
      "Test",
      "IntegrationTests",
      "Specs",
      "Spec"
    ]
  },
  "UiSeparation": {
    "BlazorRequireCodeBehind": true,
    "BlazorRequireCssIsolation": false,
    "WpfRequireMinimalCodeBehind": true,
    "WpfCodeBehindBaseTypes": [
      "Window",
      "UserControl",
      "Page",
      "NavigationWindow"
    ],
    "BlazorExcludeFileNames": [
      "_Imports.razor"
    ],
    "WpfExcludeClassNames": [],
    "BlazorCssIsolationOnlyWhenStylesNeeded": true
  },
  "FileFilters": {
    "ExcludeFilePatterns": [
      "*.designer.cs",
      "*.g.cs",
      "*.generated.cs",
      "AssemblyInfo.cs",
      "*.AssemblyAttributes.cs"
    ],
    "ExcludeDirectoryPatterns": [
      "obj/",
      "bin/"
    ],
    "SkipGeneratedCodeAttribute": true
  },
  "Web": {
    "IsEnabled": true,
    "Css": {
      "MaxCssLineCount": 300,
      "PreferScopedCss": true,
      "PreferScopedCssMinRuleCount": 5,
      "MaxCssSelectorComplexity": 3,
      "ExemptPaths": [
        "**/wwwroot/lib/**",
        "**/node_modules/**",
        "**/*.min.css"
      ]
    },
    "Js": {
      "MaxJsLineCount": 150,
      "EnforceJsModules": true,
      "ExemptPaths": [
        "**/wwwroot/lib/**",
        "**/node_modules/**",
        "**/ClientTests/**",
        "**/*.min.js"
      ]
    },
    "Razor": {
      "MaxRazorLineCount": 300,
      "MaxRazorCodeBlockLines": 20,
      "MaxMarkupNestingDepth": 6,
      "BanInlineEventLambdas": true,
      "MaxControlFlowBlocks": 8,
      "MaxForeachNestingDepth": 2,
      "MaxComponentParameterCount": 5,
      "BanInlineTernaryInAttributes": true
    }
  },
  "RuleMetadata": {
    "MaxLineCount": {
      "Severity": "error",
      "Intent": "agent-context"
    },
    "MaxMethodLineCount": {
      "Severity": "error",
      "Intent": "agent-context"
    },
    "MaxCognitiveComplexity": {
      "Severity": "error",
      "Intent": "agent-context"
    },
    "MaxCyclomaticComplexity": {
      "Severity": "error",
      "Intent": "agent-context"
    },
    "AllowOutParameters": {
      "Severity": "warning",
      "Intent": "csharp-idiom"
    },
    "StaticTestSentinel": {
      "Severity": "warning",
      "Intent": "test-coverage"
    },
    "EnforceMinimalApiAsParameters": {
      "Severity": "error",
      "Intent": "aspnet-binding"
    },
    "EnforceNoSilentCatch": {
      "Severity": "error",
      "Intent": "agent-resilience"
    },
    "EnforceNoVariableShadowing": {
      "Severity": "error",
      "Intent": "agent-resilience"
    },
    "EnforceReadonlyParameters": {
      "Severity": "error",
      "Intent": "agent-resilience"
    },
    "EnforceReadonlyFields": {
      "Severity": "error",
      "Intent": "agent-resilience"
    },
    "EnforceNoMagicValues": {
      "Severity": "warning",
      "Intent": "semantic-naming"
    },
    "EnforceResultPatternOverExceptions": {
      "Severity": "error",
      "Intent": "control-flow"
    },
    "MaxConstructorDependencies": {
      "Severity": "error",
      "Intent": "coupling"
    },
    "MaxMethodOverloads": {
      "Severity": "error",
      "Intent": "api-surface"
    },
    "AIContextFootprint": {
      "Severity": "warning",
      "Intent": "agent-context"
    },
    "EnforceExplicitStateImmutability": {
      "Severity": "error",
      "Intent": "agent-resilience"
    },
    "EnforceStrictBoundaryForBusinessLogic": {
      "Severity": "error",
      "Intent": "architecture"
    },
    "PreventContextDependentOverloads": {
      "Severity": "error",
      "Intent": "agent-context"
    },
    "RequireExplicitTruncationHandling": {
      "Severity": "warning",
      "Intent": "agent-resilience"
    },
    "EnforceNamespaceDirectoryMapping": {
      "Severity": "error",
      "Intent": "architecture"
    },
    "MaxDirectoryDepth": {
      "Severity": "warning",
      "Intent": "agent-context"
    },
    "DetectAndBanPhantomDependencies": {
      "Severity": "error",
      "Intent": "architecture"
    }
  },
  "ForbiddenNamespaceDependencies": [],
  "ProjectOverrides": {
    "*.Tests": {
      "Global": {
        "EnforceSealedClasses": false,
        "EnforceExplicitStateImmutability": false,
        "DetectAndBanPhantomDependencies": false
      },
      "Metrics": {
        "MaxMethodParameterCountInTestFiles": 10,
        "MaxMethodLineCount": 100,
        "MaxAIContextFootprint": 8000,
        "MaxDirectoryDepth": 12
      }
    }
  },
  "PathOverrides": {
    "San.smart.Planner.Platform/Components/Pages/Test/**": {
      "Metrics": {
        "MaxAIContextFootprint": 10000
      }
    },
    "San.smart.Planner.Platform/Handlers/Admin/Ai/Patches/**": {
      "Metrics": {
        "MaxMethodParameterCount": 8
      }
    },
    "San.smart.Planner.Platform/Handlers/Admin/Ai/Plugin/**": {
      "Metrics": {
        "MaxMethodParameterCount": 10
      }
    },
    "San.smart.Planner.Platform.Tests/Handlers/Admin/Ai/Exploration/**": {
      "Metrics": {
        "MaxMethodLineCount": 160,
