      }
    },
    "San.smart.Planner.Platform.Tests/Handlers/Admin/AdminBackendHandlerIntegrationTests.cs": {
      "Metrics": {
        "MaxMethodLineCount": 130
      }
    },
    "San.smart.Planner.Platform.Tests/Handlers/Admin/Ai/AiChatRollbackIntegrationTests.cs": {
      "Metrics": {
        "MaxMethodLineCount": 120
      }
    },
    "San.smart.Planner.Platform.Tests/Handlers/TimelineViewLabSchedulerHandlerTests.cs": {
      "Metrics": {
